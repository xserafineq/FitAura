{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**/*.cs"
          ],
          "src": "."
        }
      ]
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.md"
        ]
      },
      {
        "files": [
          "api/*.yml"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ]
  }
}