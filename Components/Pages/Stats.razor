@page "/stats"
@using FitAura.Models
@using FitAura.Services
@inject DayService DayService
@inject UserState UserState
@inject NavigationManager NavigationManager

<main>
    <div id="stats-card">
        <div id="stats-header">
            <h2>Statystyki</h2>
            <p>Monitoruj swoje postępy i BMI</p>
        </div>

        <div class="date-picker-container">
            <div class="date-field">
                <label>Od:</label>
                <input type="date" @bind="startDate" />
            </div>
            <div class="date-field">
                <label>Do:</label>
                <input type="date" @bind="endDate" />
            </div>
            <button class="btn-refresh" @onclick="LoadStatistics">Aktualizuj</button>
        </div>

        @if (isLoading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
                <p>Ładowanie statystyk...</p>
            </div>
        }
        else if (daysList == null || daysList.Count == 0)
        {
            <div class="no-data">
                Brak danych dla wybranego okresu. Wprowadź posiłki, kroki lub pomiary na ekranie głównym!
            </div>
        }
        else
        {
            <div class="metrics-grid">
                <div class="metric-box">
                    <div class="metric-icon"><img src="images/kcal.svg" width="25" height="25" /></div>
                    <div class="metric-title">Średnio spalone kalorie</div>
                    <div class="metric-value">@avgBurnedKcal.ToString("N0") kcal</div>
                </div>

                <div class="metric-box">
                    <div class="metric-icon"><img src="images/steps.svg" width="25" height="25" /></div>
                    <div class="metric-title">Średnia ilość kroków</div>
                    <div class="metric-value">@avgSteps.ToString("N0")</div>
                </div>

                <div class="metric-box">
                    <div class="metric-icon"><img src="images/dream.svg" width="25" height="25" /></div>
                    <div class="metric-title">Średni poziom snu</div>
                    <div class="metric-value">@avgSleepLabel</div>
                    <div class="metric-sub">Średnia ocena: @avgSleepScore.ToString("F1") / 3.0</div>
                </div>

                <div class="metric-box">
                    <div class="metric-icon"><img src="images/fi-bs-hamburger.svg" width="25" height="25" /></div>
                    <div class="metric-title">Średni cukier</div>
                    <div class="metric-value">@(avgSugar > 0 ? avgSugar.ToString("F1") : "-")</div>
                </div>

                <div class="metric-box">
                    <div class="metric-icon"><img src="images/trening.svg" width="25" height="25" /></div>
                    <div class="metric-title">Średnie tętno</div>
                    <div class="metric-value">@(avgPulse > 0 ? avgPulse.ToString("F1") : "-")</div>
                </div>
            </div>

            <div class="chart-container">
                <h3>Wykres zmian BMI</h3>
                <div class="bmi-badge @bmiCategoryClass">
                    Aktualne BMI w tym okresie: @latestBmi.ToString("F1") (@bmiCategoryLabel)
                </div>

                @if (bmiData.Count >= 1)
                {
                    <FitAura.Components.Charts.BmiChart Data="bmiData" MinYVal="minYVal" MaxYVal="maxYVal"
                        MinYLabel="@minYLabel" MidYLabel="@midYLabel" MaxYLabel="@maxYLabel" />
                }
                else
                {
                    <div class="no-chart-data">
                        Brak danych do wykreślenia zmian BMI. Dodaj pomiary!
                    </div>
                }
            </div>

        }
    </div>
</main>

@code {
    private DateTime startDate = DateTime.Today.AddDays(-7);
    private DateTime endDate = DateTime.Today;

    private bool isLoading = true;

    private List<Day> daysList = new();
    private List<BmiPoint> bmiData = new();

    private double avgBurnedKcal = 0;
    private double avgSteps = 0;
    private double avgSleepScore = 0;
    private string avgSleepLabel = "Brak danych";

    private double latestBmi = 0;
    private string bmiCategoryLabel = "Brak danych";
    private string bmiCategoryClass = "bmi-normal";

    private double avgSugar = 0;
    private double avgPulse = 0;

    private double minYVal = 15;
    private double maxYVal = 35;
    private string minYLabel = "15";
    private string midYLabel = "25";
    private string maxYLabel = "35";

    public class BmiPoint
    {
        public DateOnly Date { get; set; }
        public double Bmi { get; set; }
        public double Weight { get; set; }
    }

    public class ChartPoint
    {
        public DateOnly Date { get; set; }
        public double Value { get; set; }
        public string TooltipData { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
    }

    private async Task LoadStatistics()
    {
        isLoading = true;
        StateHasChanged();

        var user = UserState.CurrentUser;
        if (user == null)
        {
            isLoading = false;
            return;
        }

        var startOnly = DateOnly.FromDateTime(startDate);
        var endOnly = DateOnly.FromDateTime(endDate);


        var allDays = await DayService.GetUserDaysAsync(user.Id);


        daysList = allDays
        .Where(d => d.Date >= startOnly && d.Date <= endOnly)
        .OrderBy(d => d.Date)
        .ToList();

        if (daysList.Count > 0)
        {

            avgBurnedKcal = daysList.Average(d => (double)d.KcalBurned);
            avgSteps = daysList.Average(d => (double)d.Steps);


            avgSleepScore = daysList.Average(d => d.SleepLevel);

            if (avgSleepScore < 1.5)
            {
                avgSleepLabel = "Niewyspany";
            }
            else if (avgSleepScore < 2.5)
            {
                avgSleepLabel = "Średnio wyspany";
            }
            else
            {
                avgSleepLabel = "Wyspany!";
            }

            bmiData.Clear();
            avgSugar = 0;
            avgPulse = 0;
            int sugarCount = 0;
            int pulseCount = 0;
            double heightM = (double)user.Height;
            if (heightM > 3) heightM /= 100.0;

            foreach (var day in daysList)
            {
                if (day.Measurements != null && day.Measurements.Any())
                {
                    var measurement = day.Measurements.Last();
                    double dayWeight = (double)measurement.Weight;
                    double bmi = dayWeight / (heightM * heightM);
                    bmiData.Add(new BmiPoint
                        {
                            Date = day.Date,
                            Bmi = bmi,
                            Weight = dayWeight
                        });

                    double sugar = (double)measurement.Sugar;
                    if (sugar > 0)
                    {
                        avgSugar += sugar;
                        sugarCount++;
                    }

                    double pulse = (double)measurement.Pulse;
                    if (pulse > 0)
                    {
                        avgPulse += pulse;
                        pulseCount++;
                    }
                }
            }

            if (sugarCount > 0) avgSugar /= sugarCount;
            if (pulseCount > 0) avgPulse /= pulseCount;

            if (bmiData.Count > 0)
            {
                latestBmi = bmiData.Last().Bmi;
                DetermineBmiCategory(latestBmi);


                double minB = bmiData.Min(d => d.Bmi);
                double maxB = bmiData.Max(d => d.Bmi);
                minYVal = Math.Max(10, Math.Min(minB - 2, 18));
                maxYVal = Math.Min(50, Math.Max(maxB + 2, 28));

                minYLabel = minYVal.ToString("F0");
                maxYLabel = maxYVal.ToString("F0");
                midYLabel = ((minYVal + maxYVal) / 2.0).ToString("F0");
            }
        }
        else
        {
            avgBurnedKcal = 0;
            avgSteps = 0;
            avgSleepScore = 0;
            avgSugar = 0;
            avgPulse = 0;
            avgSleepLabel = "Brak danych";
            bmiData.Clear();
            latestBmi = 0;
            bmiCategoryLabel = "Brak danych";
        }

        isLoading = false;
    }

    private void DetermineBmiCategory(double bmi)
    {
        if (bmi < 18.5)
        {
            bmiCategoryLabel = "Niedowaga";
            bmiCategoryClass = "bmi-underweight";
        }
        else if (bmi < 25.0)
        {
            bmiCategoryLabel = "Waga prawidłowa";
            bmiCategoryClass = "bmi-normal";
        }
        else if (bmi < 30.0)
        {
            bmiCategoryLabel = "Nadwaga";
            bmiCategoryClass = "bmi-overweight";
        }
        else
        {
            bmiCategoryLabel = "Otyłość";
            bmiCategoryClass = "bmi-obese";
        }
    }


}
