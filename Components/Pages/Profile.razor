@page "/profile"
@inject UserState UserState
@inject UserService UserService

<section id="profile">
    <div id="username">
        <p>Użytkownik <span>@UserState.CurrentUser?.Email</span></p>
    </div>
    <form @onsubmit="HandleSave">
        <div id="weight">
            <span>Waga</span><input type="number" step="0.1" @bind="weight" placeholder="[kg]" />
        </div>
        <div id="height">
            <span>Wzrost</span><input type="number" step="0.1" @bind="height" placeholder="[cm]" />
        </div>
        <div id="password">
            <span>Hasło</span><input type="password" @bind="password" placeholder="nowe hasło" />
        </div>
        @* <div id="activity">
        <span>Aktywność fizyczna</span>
        <select type="number" placeholder="[cm]">
        <option selected value="3">Wysoka</option>
        <option value="2">Średnia</option>
        <option value="1">Niska</option>
        <option value="0">Brak</option>
        </select>
        </div> *@
        <div id="btns">
            <button type="submit" class="accept">Zapisz</button>
            <button type="button" class="cancel" @onclick="HandleCancel">Anuluj</button>
        </div>
    </form>
</section>

@code {
    private decimal weight;
    private decimal height;
    private string password = string.Empty;

    protected override void OnInitialized()
    {
        if (UserState.CurrentUser != null)
        {
            weight = UserState.CurrentUser.Weight;
            height = UserState.CurrentUser.Height;
            password = UserState.CurrentUser.Password;
        }
    }

    private async Task HandleSave()
    {
        if (UserState.CurrentUser == null) return;

        var updatedUser = UserState.CurrentUser with
        {
            Weight = weight,
            Height = height,
            Password = string.IsNullOrWhiteSpace(password) ? UserState.CurrentUser.Password : password
        };

        var success = await UserService.UpdateUserAsync(updatedUser);
        if (success)
        {
            UserState.SetUser(updatedUser);
            // Optionally add some notification here
        }
    }

    private void HandleCancel()
    {
        if (UserState.CurrentUser != null)
        {
            weight = UserState.CurrentUser.Weight;
            height = UserState.CurrentUser.Height;
            password = UserState.CurrentUser.Password;
        }
    }
}
