@page "/home"
@using FitAura.Components.Cards
@using FitAura.Components.Modals
@using FitAura.Models
@using FitAura.Models.Records
@inject DayState DayState
@inject UserState UserState


<main>
    <div id="today">
        <div id="date">@displayDate</div>
        <div id="kcal">@consumedKcal / @dailyCaloricDemand kcal</div>
    </div>
    <section id="meals">

        @{
            if (meals.Count>0)
            {
                foreach (var meal in meals)
                {
                    <Meal name="@meal.Name" kcal="@meal.Kcal" mealItems="@meal.MealItems" isFilled="true"></Meal>
                }
            }
            <Meal name="Nowy posiłek" />
        }
    </section>
    <section id="diary">
        <p>Dziennik Aktywności</p>
        <div id="container">
            <Activity name="Trening" activityIcon="trening.svg">
                @kcal
            </Activity>
            <Activity name="Sen" activityIcon="dream.svg">
                <div>@{
                            if(sleep == 1)
                            {
                               <span>nie wyspany</span>
                            }
                            if(sleep == 2)
                            {
                               <span>śrenio wyspany</span>
                            }
                            if(sleep == 3)
                            {
                               <span>wyspany</span>
                            }
                     }</div>
            </Activity>
            <Activity name="Kroki" activityIcon="steps.svg">
                @steps
            </Activity>
            <Activity name="pomiary" activityIcon="measurements.svg">
                @measurementsCount
            </Activity>
        </div>
    </section>
</main>

@code {
    private string? displayDate;

    private decimal kcal;
    private decimal consumedKcal;
    private int steps;
    private int sleep;
    private int measurementsCount;
    private List<AddMealRecord> meals = new();
    private int dailyCaloricDemand = 2000;

    protected override void OnInitialized()
    {
        displayDate = DayState.CurrentDay.Date.ToString();

        DayState.OnChange += HandleStateChange;
        CalculateCaloricDemand();
        RefreshData();
    }

    private void CalculateCaloricDemand()
    {
        var user = UserState.CurrentUser;
        if (user != null)
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            int age = today.Year - user.BirthDate.Year;
            if (user.BirthDate > today.AddYears(-age))
            {
                age--;
            }

            double bmr = 0;
            if (user.Sex != null && user.Sex.Equals("Male", StringComparison.OrdinalIgnoreCase))
            {
                bmr = 10 * (double)user.Weight + 6.25 * (double)user.Height - 5 * age + 5;
            }
            else
            {
                bmr = 10 * (double)user.Weight + 6.25 * (double)user.Height - 5 * age - 161;
            }

           
            dailyCaloricDemand = (int)Math.Round(bmr * 1.4);
        }
        else
        {
            dailyCaloricDemand = 2000;
        }
    }

    private void RefreshData()
    {
        if (DayState.CurrentDay != null)
        {
            kcal = DayState.CurrentDay.KcalBurned;
            steps = DayState.CurrentDay.Steps;
            sleep = DayState.CurrentDay.SleepLevel;
            measurementsCount = DayState.CurrentDay.Measurements?.Count() ?? 0;
            meals = DayState.CurrentDay.Meals?.ToList() ?? new List<AddMealRecord>();
            consumedKcal = 0;
            if (DayState.CurrentDay.Meals != null)
            {
                foreach (var meal in DayState.CurrentDay.Meals)
                {
                    consumedKcal += meal.Kcal;
                }
            }
        }
    }

    private void HandleStateChange()
    {
        CalculateCaloricDemand();
        RefreshData();
        InvokeAsync(StateHasChanged);
    }
}