@page "/home"
@using FitAura.Components.Cards
@using FitAura.Components.Modals
@using FitAura.Models
@using FitAura.Models.Records
@inject DayState DayState


<main>
    <div id="today">
        <div id="date">@displayDate</div>
        <div id="kcal">@consumedKcal / 2000 kcal</div>
    </div>
    <section id="meals">

        @{
            if (meals.Count>0)
            {
                foreach (var meal in meals)
                {
                    <Meal name="@meal.Name" kcal="@meal.Kcal" mealItems="@meal.MealItems" isFilled="true"></Meal>
                }
            }
            <Meal name="Nowy posiłek" />
        }
    </section>
    <section id="diary">
        <p>Dziennik Aktywności</p>
        <div id="container">
            <Activity name="Trening" activityIcon="trening.svg">
                @kcal
            </Activity>
            <Activity name="Sen" activityIcon="dream.svg">
                <div>@{
                            if(sleep == 1)
                            {
                               <span>nie wyspany</span>
                            }
                            if(sleep == 2)
                            {
                               <span>śrenio wyspany</span>
                            }
                            if(sleep == 3)
                            {
                               <span>wyspany</span>
                            }
                     }</div>
            </Activity>
            <Activity name="Kroki" activityIcon="steps.svg">
                @steps
            </Activity>
            <Activity name="pomiary" activityIcon="measurements.svg">
                @measurementsCount
            </Activity>
        </div>
    </section>
</main>

@code {
    private string? displayDate;

    private decimal kcal;
    private decimal consumedKcal;
    private int steps;
    private int sleep;
    private int measurementsCount;
    private List<AddMealRecord> meals;

    protected override void OnInitialized()
    {
        displayDate = DayState.CurrentDay.Date.ToString();

        DayState.OnChange += HandleStateChange;
        RefreshData();
    }

    private void RefreshData()
    {
        if (DayState.CurrentDay != null)
        {
            kcal = DayState.CurrentDay.KcalBurned;
            steps = DayState.CurrentDay.Steps;
            sleep = DayState.CurrentDay.SleepLevel;
            measurementsCount = DayState.CurrentDay.Measurements.Count();
            meals = DayState.CurrentDay.Meals?.ToList() ?? new List<AddMealRecord>();
            consumedKcal = 0;
            foreach (var meal in DayState.CurrentDay.Meals)
            {
                consumedKcal += meal.Kcal;
            }
        }
    }

    private void HandleStateChange()
    {
        RefreshData();
        InvokeAsync(StateHasChanged);
    }
}