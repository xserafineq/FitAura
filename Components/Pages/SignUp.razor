@page "/signup"
@using FitAura.Models
@using FitAura.Services
@layout EmptyLayout

@inject NavigationManager NavigationManager
@inject UserService UserService
@inject DayService DayService
@inject UserState UserState

<main>
    <div id="form-box">
        <div id="form-header">
            <img src="images/logo.png" alt="FitAura Logo" height="40"/>
            <div>FitAura</div>
        </div>

        <form @onsubmit="HandleSignUp" @onsubmit:preventDefault>
            <input type="text" placeholder="Imię" @bind="firstname" required />
            <input type="text" placeholder="Nazwisko" @bind="lastname" required />
            <input type="email" placeholder="Email" @bind="email" required />
            <input type="password" placeholder="Hasło" @bind="password" required />
            
            <div class="row">
                <div class="col">
                    <label class="input-label">Data urodzenia</label>
                    <input type="date" placeholder="Data urodzenia" @bind="birthDate" required />
                </div>
                <div class="col">
                    <label class="input-label">Płeć</label>
                    <select class="sex-select" @bind="sex" required>
                        <option value="" disabled>Wybierz...</option>
                        <option value="Male">Mężczyzna</option>
                        <option value="Female">Kobieta</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label class="input-label">Waga (kg)</label>
                    <input type="number" step="0.1" placeholder="Waga" @bind="weight" min="1" required />
                </div>
                <div class="col">
                    <label class="input-label">Wzrost (cm)</label>
                    <input type="number" step="0.1" placeholder="Wzrost" @bind="height" min="1" required />
                </div>
            </div>

            <button type="submit">Zarejestruj się</button>
        </form>

        <div class="signin-link">
            Masz już konto? <a href="/">Zaloguj się</a>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">
                @errorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="success-message">
                @successMessage
            </div>
        }
    </div>
</main>

@code {
    private string firstname = "";
    private string lastname = "";
    private string email = "";
    private string password = "";
    private DateTime? birthDate = DateTime.Today.AddYears(-20);
    private decimal weight = 70;
    private decimal height = 175;
    private string sex = "Male";

    private string? errorMessage;
    private string? successMessage;

    private async Task HandleSignUp()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(firstname) ||
            string.IsNullOrWhiteSpace(lastname) ||
            string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password) ||
            birthDate == null ||
            weight <= 0 ||
            height <= 0 ||
            string.IsNullOrWhiteSpace(sex))
        {
            errorMessage = "Wszystkie pola są wymagane i muszą być poprawne.";
            return;
        }

        try
        {
            var dateOnly = DateOnly.FromDateTime(birthDate.Value);
            var newUser = new User(0, email, firstname, lastname, dateOnly, weight, height, password, sex);

            var registeredUser = await UserService.RegisterAsync(newUser);

            if (registeredUser != null)
            {
                successMessage = "Rejestracja zakończona sukcesem! Przekierowywanie...";
                StateHasChanged();
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/");
            }
            else
            {
                errorMessage = "Błąd rejestracji. Możliwe, że ten e-mail jest już zajęty.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Wystąpił błąd podczas rejestracji.";
            Console.WriteLine(ex.Message);
        }
    }
}
