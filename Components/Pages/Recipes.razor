@page "/recipes"
@using FitAura.Components.Cards
@using MudBlazor
@using System.Collections.Generic
@inject IDialogService DialogService
@inject FitAura.Services.RecipeService RecipeService
@inject FitAura.Services.CategoryService CategoryService
@inject UserState UserState

<main>
    <section id="recipes">
        @if (IsSelectionMode)



        {
            <div class="selection-header">
                <h3 class="selection-title">Wybierz przepis do posiłku</h3>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => MudDialog.Cancel()" />
            </div>
        }

        else

        {
            <p>Wyszukaj przepis</p>
        }

        <div id="search-filters">
            <div id="search">
                <input id="recipe-input" type="text" placeholder="wyszukaj przepis" @bind="searchQuery"
                @onkeyup="HandleSearchEnter" />
                
                <div @onclick="ToggleAdvancedFilters" class="filter-icon" style="cursor:pointer;" title="Filtry">
                    <img height="18" src="images/filter.svg" />
                </div>

                @if (!IsSelectionMode)
                {
                    <div @onclick="openAddDialog" class="filter-icon" style="cursor:pointer;" title="Dodaj przepis">
                        <img height="18" src="images/add.svg" />
                    </div>
                }
            </div>

            @if (showAdvancedFilters)
            {
                <div class="advanced-filters-container" style="background-color: #f9f9f9; padding: 15px; border-radius: 12px; border: 1px solid #eee; display: flex; flex-direction: column; gap: 15px;">
                    <div class="advanced-filters" style="padding: 0; border: none; background: transparent;">
                        <input type="number" placeholder="min kcal" @bind="minKcal" @bind:event="oninput" @onkeyup="HandleSearchEnter" @onblur="LoadRecipes" />
                        <input type="number" placeholder="max kcal" @bind="maxKcal" @bind:event="oninput" @onkeyup="HandleSearchEnter" @onblur="LoadRecipes" />
                        <input type="email" placeholder="email autora" @bind="authorEmail" @bind:event="oninput" @onkeyup="HandleSearchEnter" @onblur="LoadRecipes" />
                        <select @bind="sortMode" @bind:after="LoadRecipes">
                            <option value="">Domyślne sortowanie</option>
                            <option value="kcal_asc">Kcal: rosnąco</option>
                            <option value="kcal_desc">Kcal: malejąco</option>
                        </select>
                        <select value="@categoryFilterValue" @onchange="OnCategoryFilterChanged">
                            <option value="all">Wszystkie kategorie</option>
                            <option value="mine">Moje przepisy</option>
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id.ToString()">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            }
        </div>

        <div id="container">
            @if (recipes != null)
            {
                @if (recipes.Any())



                {
                    @foreach (var r in recipes)



                    {
                        <Recipe id="@r.Id" name="@r.Name" kcal="@r.TotalKcal" protein="@r.TotalProtein" carbs="@r.TotalCarbs"
                            fats="@r.TotalFats" img="@(string.IsNullOrEmpty(r.ImageUrl) ? "img-not-found.png" : r.ImageUrl)"
                            categories="@(r.Categories ?? new List<string>())" OnSelected="HandleRecipeSelected"
                            IsEditable="@isMyRecipes" />
                    }
                }



                else



                {
                    <p class="no-recipes-found">Nie znaleziono przepisów.</p>
                }
            }
            else
            {
                <p>Ładowanie przepisów...</p>
            }
        </div>
    </section>
</main>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;



    [Parameter] public bool IsSelectionMode { get; set; } = false;







    private string searchQuery = "";
    private int? minKcal = null;
    private int? maxKcal = null;
    private string? authorEmail = null;
    private string? sortMode = null;
    private bool showAdvancedFilters = false;

    private void ToggleAdvancedFilters()
    {
        showAdvancedFilters = !showAdvancedFilters;
    }

    private int? selectedCategoryId = null;
    private bool isMyRecipes = false;

    private string categoryFilterValue => isMyRecipes ? "mine" : (selectedCategoryId?.ToString() ?? "all");

    private async Task OnCategoryFilterChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (val == "mine")
        {
            isMyRecipes = true;
            selectedCategoryId = null;
        }
        else if (val == "all")
        {
            isMyRecipes = false;
            selectedCategoryId = null;
        }
        else if (int.TryParse(val, out int id))
        {
            isMyRecipes = false;
            selectedCategoryId = id;
        }
        await LoadRecipes();
    }



    private List<FitAura.Services.RecipeSummaryDto> recipes = new();



    private List<FitAura.Models.CategoryModel> categories = new();







    protected override async Task OnInitializedAsync()


    {

        try
        {
            categories = await CategoryService.GetCategoriesAsync();
        }

        catch (Exception ex)

        {
            Console.WriteLine($"Błąd pobierania kategorii: {ex.Message}");
            categories = new();
        }

        await LoadRecipes();

    }







    private async Task LoadRecipes()

    {

        try
        {
            recipes = await RecipeService.GetRecipesAsync(
                searchQuery, 
                minKcal,
                maxKcal, 
                isMyRecipes ? null : selectedCategoryId,
                isMyRecipes ? UserState.CurrentUser?.Id : null,
                authorEmail,
                sortMode
            );
        }

        catch (Exception ex)

        {

            Console.WriteLine($"Błąd pobierania przepisów: {ex.Message}");

            recipes = new();

        }
    }







    private async Task SelectCategory(int? categoryId)

    {

        selectedCategoryId = categoryId;
        isMyRecipes = false;
        await LoadRecipes();



    }

    private async Task HandleSearchEnter(KeyboardEventArgs e)

    {

        if (e.Key == "Enter")

        {

            await LoadRecipes();

        }
    }







    private async Task HandleRecipeSelected(FitAura.Services.RecipeSummaryDto selectedRecipe)
    {
        if (IsSelectionMode && MudDialog != null)
        {
            MudDialog.Close(DialogResult.Ok(selectedRecipe));
        }
        else if (isMyRecipes)
        {
            await EditRecipe(selectedRecipe);
        }
        else
        {
            var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small };
            var parameters = new DialogParameters<FitAura.Components.Modals.Show.ShowRecipe> { { x => x.RecipeId, selectedRecipe.Id } };
            await DialogService.ShowAsync<FitAura.Components.Modals.Show.ShowRecipe>("Szczegóły przepisu", parameters, options);
        }
    }








    public async Task openAddDialog()



    {



        var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small };



        var dialog = await DialogService.ShowAsync<FitAura.Components.Modals.Add.AddRecipe>("Dodaj nowy przepis", options);



        var result = await dialog.Result;







        if (result != null && !result.Canceled)



        {



            await LoadRecipes();



        }



    }

    private async Task SelectMyRecipes()
    {
        isMyRecipes = true;
        selectedCategoryId = null;
        await LoadRecipes();
    }

    private async Task EditRecipe(FitAura.Services.RecipeSummaryDto selectedRecipe)
    {
        var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small };
        var parameters = new DialogParameters<FitAura.Components.Modals.Add.AddRecipe>
        {
            { x => x.EditRecipeId, selectedRecipe.Id }
        };
        var dialog = await DialogService.ShowAsync<FitAura.Components.Modals.Add.AddRecipe>("Edytuj przepis", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadRecipes();
        }
    }
}