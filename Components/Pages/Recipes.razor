@page "/recipes"
@using FitAura.Components.Cards
@using MudBlazor
@using System.Collections.Generic
@inject IDialogService DialogService
@inject FitAura.Services.RecipeService RecipeService
@inject FitAura.Services.CategoryService CategoryService
@inject UserState UserState

<main>
    <section id="recipes">
        @if (IsSelectionMode)



        {
            <div class="selection-header">
                <h3 class="selection-title">Wybierz przepis do posiłku</h3>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="() => MudDialog.Cancel()" />
            </div>
        }

        else

        {
            <p>Wyszukaj przepis</p>
        }

        <div id="search-filters">
            <div id="search">
                <input id="recipe-input" type="text" placeholder="wyszukaj przepis" @bind="searchQuery"
                @onkeyup="HandleSearchEnter" />
                <input type="number" id="max-kcal" placeholder="max kcal" @bind="maxKcal"
                @onkeyup="HandleSearchEnter" />
                @*<div @onclick="LoadRecipes" class="filter-icon"><img height="15" src="images/filter.svg" /></div>*@
                @if (!IsSelectionMode)



                {
                    <div @onclick="openAddDialog" class="filter-icon"><img height="18" src="images/add.svg" /> </div>
                }
            </div>

            <div class="category-filters">
                <div class="filter-chip @(selectedCategoryId == null ? "active" : "")"
                @onclick="() => SelectCategory(null)">
                    Wszystkie
                </div>
                @if (categories != null)



                {
                    @foreach (var cat in categories)
                    {
                        <div class="filter-chip @(selectedCategoryId == cat.Id && !isMyRecipes ? "active" : "")"
                        @onclick="() => SelectCategory(cat.Id)">
                            @cat.Name
                        </div>
                    }
                }
                <div class="filter-chip @(isMyRecipes ? "active" : "")"
                     @onclick="SelectMyRecipes">
                    Moje
                </div>
            </div>
        </div>

        <div id="container">
            @if (recipes != null)
            {
                @if (recipes.Any())



                {
                    @foreach (var r in recipes)



                    {
                        <Recipe id="@r.Id" name="@r.Name" kcal="@r.TotalKcal" protein="@r.TotalProtein" carbs="@r.TotalCarbs"
                            fats="@r.TotalFats" img="@(string.IsNullOrEmpty(r.ImageUrl) ? "sushi.png" : r.ImageUrl)"
                            categories="@(r.Categories ?? new List<string>())" OnSelected="HandleRecipeSelected"
                            IsEditable="@isMyRecipes" />
                    }
                }



                else



                {
                    <p class="no-recipes-found">Nie znaleziono przepisów.</p>
                }
            }
            else
            {
                <p>Ładowanie przepisów...</p>
            }
        </div>
    </section>
</main>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }



    [Parameter] public bool IsSelectionMode { get; set; } = false;







    private string searchQuery = "";



    private int? maxKcal = null;



    private int? selectedCategoryId = null;

    private bool isMyRecipes = false;



    private List<FitAura.Services.RecipeSummaryDto> recipes;



    private List<FitAura.Models.CategoryModel> categories = new();







    protected override async Task OnInitializedAsync()


    {

        try
        {
            categories = await CategoryService.GetCategoriesAsync();
        }

        catch (Exception ex)

        {
            Console.WriteLine($"Błąd pobierania kategorii: {ex.Message}");
            categories = new();
        }

        await LoadRecipes();

    }







    private async Task LoadRecipes()

    {

        try

        {
        recipes = await RecipeService.GetRecipesAsync(
            searchQuery, 
            maxKcal, 
            isMyRecipes ? null : selectedCategoryId,
            isMyRecipes ? UserState.CurrentUser?.Id : null
        );

        }

        catch (Exception ex)

        {

            Console.WriteLine($"Błąd pobierania przepisów: {ex.Message}");

            recipes = new();

        }
    }







    private async Task SelectCategory(int? categoryId)

    {

        selectedCategoryId = categoryId;
        isMyRecipes = false;
        await LoadRecipes();



    }

    private async Task HandleSearchEnter(KeyboardEventArgs e)

    {

        if (e.Key == "Enter")

        {

            await LoadRecipes();

        }
    }







    private async Task HandleRecipeSelected(FitAura.Services.RecipeSummaryDto selectedRecipe)
    {
        if (IsSelectionMode && MudDialog != null)
        {
            MudDialog.Close(DialogResult.Ok(selectedRecipe));
        }
        else if (isMyRecipes)
        {
            await EditRecipe(selectedRecipe);
        }
        else
        {
            var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small };
            var parameters = new DialogParameters<FitAura.Components.Modals.Show.ShowRecipe> { { x => x.RecipeId, selectedRecipe.Id } };
            await DialogService.ShowAsync<FitAura.Components.Modals.Show.ShowRecipe>("Szczegóły przepisu", parameters, options);
        }
    }








    public async Task openAddDialog()



    {



        var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small };



        var dialog = await DialogService.ShowAsync<FitAura.Components.Modals.Add.AddRecipe>("Dodaj nowy przepis", options);



        var result = await dialog.Result;







        if (!result.Canceled)



        {



            await LoadRecipes();



        }



    }

    private async Task SelectMyRecipes()
    {
        isMyRecipes = true;
        selectedCategoryId = null;
        await LoadRecipes();
    }

    private async Task EditRecipe(FitAura.Services.RecipeSummaryDto selectedRecipe)
    {
        var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small };
        var parameters = new DialogParameters<FitAura.Components.Modals.Add.AddRecipe>
        {
            { x => x.EditRecipeId, selectedRecipe.Id }
        };
        var dialog = await DialogService.ShowAsync<FitAura.Components.Modals.Add.AddRecipe>("Edytuj przepis", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadRecipes();
        }
    }
}