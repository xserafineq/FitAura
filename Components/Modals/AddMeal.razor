@using MudBlazor

<MudDialog>
    <DialogContent>
        <div id="search">
            <input id="recipe-input" type="text" placeholder="nazwa" />
            <div class="filter-icon"><img height="26" src="images/add_photo.svg"</div>
            <div class="filter-icon"><img height="25" src="images/recipes.svg"</div>
        </div>
        @* <div id="img-container">
            <img id="meal-img" src="images/sushi.png" alt="product" />
        </div>
        <div id="content">
            <div>
                <div id="name">nazwa</div>
                <div id="kcal"><img height="16" src="images/kcal.svg" alt="kcal" /> 0 kcal</div>
            </div>
            <div id="nutrients">
                <div class="nutrient">0g białka</div>
                <div class="nutrient">0g węgli</div>
                <div class="nutrient">0g tłuszczy</div>
            </div>
        </div> *@
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Anuluj</MudButton>
        <MudButton Color="Color.Secondary" OnClick="Submit">Wybierz</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();
}