@using MudBlazor
@using FitAura.Services
@using System.Collections.Generic
@inject RecipeService RecipeService

<MudDialog>
    <DialogContent>
        @if (recipe == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <div id="img-container">
                <img id="meal-img" src="@ImageSource" alt="product" />
            </div>
            <div id="content">
                <div>
                    <div id="name">@recipe.Name</div>
                    <div id="recipe-categories">
                        @if (recipe.Categories != null)
                        {
                            @foreach (var cat in recipe.Categories)
                            {
                                <span class="category-tag">@cat</span>
                            }
                        }
                    </div>
                    <div id="portion">@recipe.Portions porcji</div>
                    <div id="kcal"><img height="16" src="images/kcal.svg" alt="kcal" /> @recipe.TotalKcal kcal</div>
                </div>
                <div id="indegredients">
                    <p>Składniki</p>
                    <ul>
                        @foreach (var ing in recipe.Ingredients)
                        {
                            <li>@ing.ProductName @ing.Amount @ing.Unit</li>
                        }
                    </ul>
                </div>
                <div id="steps">
                    <p>Sposób wykonania</p>
                    <ol>
                        @foreach (var step in recipe.Steps)
                        {
                            <li>@step</li>
                        }
                    </ol>
                </div>
                <div id="nutrients">
                    <div class="nutrient">@recipe.TotalProtein g białka</div>
                    <div class="nutrient">@recipe.TotalCarbs g węgli</div>
                    <div class="nutrient">@recipe.TotalFats g tłuszczy</div>
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Zamknij</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int RecipeId { get; set; }

    private RecipeDetailDto? recipe;

    protected override async Task OnInitializedAsync()
    {
        recipe = await RecipeService.GetRecipeAsync(RecipeId);
    }

    private string ImageSource => (recipe?.ImageUrl != null && recipe.ImageUrl.StartsWith("/"))
    ? $"{FitAura.Config.ImageBaseUrl}{recipe.ImageUrl}"
    : (string.IsNullOrEmpty(recipe?.ImageUrl) ? "images/sushi.png" : $"images/{recipe.ImageUrl}");

    private void Cancel() => MudDialog.Cancel();
}