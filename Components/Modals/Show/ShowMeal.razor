@using FitAura.Models.Records
@using FitAura.Services
@using MudBlazor
@inject MealService MealService
@inject RecipeService RecipeService

<style>
    .meal-item-card {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px;
        background: #fdfdfd;
        border-radius: 12px;
        margin-bottom: 12px;
        border: 1px solid #eee;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .item-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #f0f0f0;
    }

    .item-info {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .item-name {
        font-weight: bold;
        font-size: 15px;
        color: #222;
    }

    .item-meta {
        font-size: 12px;
        color: #666;
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .item-type-tag {
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 10px;
        font-weight: bold;
        text-transform: uppercase;
    }

    .macros-row {
        display: flex;
        gap: 10px;
        margin-top: 4px;
        font-size: 11px;
        color: #888;
    }

    .macro-val {
        font-weight: 600;
        color: #444;
    }

    .item-kcal-box {
        text-align: right;
        min-width: 80px;
    }

    .item-kcal {
        font-weight: 900;
        color: var(--green);
        font-size: 16px;
    }

    .kcal-label {
        font-size: 10px;
        color: #999;
        text-transform: uppercase;
    }
</style>

<MudDialog>
    <DialogContent>
        <div id="items-list-box" style="max-height: 500px; overflow-y: auto; padding: 10px 5px;">
            @if (isLoading)
            {
                <div style="text-align: center; padding: 40px;">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <p style="margin-top: 15px; color: #666; font-weight: 500;">Pobieramy szczegóły Twojego posiłku...</p>
                </div>
            }
            else if (displayItems.Any())
            {
                @foreach (var item in displayItems)
                {
                    <div class="meal-item-card">
                        <img class="item-img" src="@GetImageSource(item)" alt="item" />
                        <div class="item-info">
                            <div class="item-name">@item.Name</div>
                            <div class="item-meta">
                                <span class="item-type-tag" style="background: @(item.IsRecipe ? "#e8f5e9" : "#f5f5f5"); color: @(item.IsRecipe ? "#2e7d32" : "#757575")">
                                    @(item.IsRecipe ? "PRZEPIS" : "PRODUKT")
                                </span>
                                <span>Ilość: <span style="font-weight: bold; color: #333;">@item.Amount @(item.IsRecipe ? "porcji" : "g")</span></span>
                            </div>
                            <div class="macros-row">
                                <span>B: <span class="macro-val">@item.Protein</span>g</span>
                                <span>W: <span class="macro-val">@item.Carbs</span>g</span>
                                <span>T: <span class="macro-val">@item.Fats</span>g</span>
                            </div>
                        </div>
                        <div class="item-kcal-box">
                            <div class="item-kcal">@item.Kcal</div>
                            <div class="kcal-label">kcal</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 40px; color: #bbb;">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" />
                    <p style="margin-top: 10px;">Nie znaleźliśmy składników tego posiłku.</p>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default" Variant="Variant.Text">Zamknij</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }
    [Parameter] public ICollection<MealItem> MealItems { get; set; } = new List<MealItem>();

    private List<MealItemDisplay> displayItems = new();
    private bool isLoading = true;

    private void Cancel() => MudDialog.Cancel();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        displayItems.Clear();
        
        try 
        {
            foreach (var item in MealItems)
            {
                if (item.Type == "recipe")
                {
                    var recipe = await RecipeService.GetRecipeAsync(item.RecipeId ?? 0);
                    if (recipe != null)
                    {
                        var macros = await MealService.CalculateRecipeMacros(item.RecipeId ?? 0, item.Amount);
                        displayItems.Add(new MealItemDisplay {
                            Name = recipe.Name,
                            ImageUrl = recipe.ImageUrl,
                            IsRecipe = true,
                            Amount = item.Amount,
                            Kcal = macros?.Kcal ?? 0,
                            Protein = macros?.Protein ?? 0,
                            Carbs = macros?.Carbs ?? 0,
                            Fats = macros?.Fats ?? 0
                        });
                    }
                }
                else 
                {
                    var product = await MealService.GetProductName(item.ProductId);
                    if (product != null)
                    {
                        var macros = await MealService.CalculateProductMacros(item.ProductId ?? 0, item.Amount);
                        displayItems.Add(new MealItemDisplay {
                            Name = product.Name,
                            ImageUrl = product.ImageUrl,
                            IsRecipe = false,
                            Amount = item.Amount,
                            Kcal = macros?.Kcal ?? 0,
                            Protein = macros?.Protein ?? 0,
                            Carbs = macros?.Carbs ?? 0,
                            Fats = macros?.Fats ?? 0
                        });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd ładowania ShowMeal: {ex.Message}");
        }
        finally 
        {
            isLoading = false;
        }
    }

    private string GetImageSource(MealItemDisplay item)
    {
        if (string.IsNullOrEmpty(item.ImageUrl)) return "images/sushi.png";
        if (item.ImageUrl.StartsWith("http")) return item.ImageUrl;
        if (item.ImageUrl.StartsWith("/")) return $"http://localhost:5096{item.ImageUrl}";
        return $"images/{item.ImageUrl}";
    }

    private class MealItemDisplay
    {
        public string Name { get; set; } = "";
        public string? ImageUrl { get; set; }
        public bool IsRecipe { get; set; }
        public int Amount { get; set; }
        public int Kcal { get; set; }
        public int Protein { get; set; }
        public int Carbs { get; set; }
        public int Fats { get; set; }
    }
}