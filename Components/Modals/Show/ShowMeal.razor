@using FitAura.Models.Records
@using FitAura.Services
@using MudBlazor
@inject MealService MealService
@inject RecipeService RecipeService

<MudDialog>
    <DialogContent>
        <div id="items-list-box">
            @if (isLoading)
            {
                <div class="loader-container">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <p class="loader-text">Pobieramy szczegóły Twojego posiłku...</p>
                </div>
            }
            else if (displayItems.Any())
            {
                @foreach (var item in displayItems)
                {
                    <div class="meal-item-card">
                        <img class="item-img" src="@GetImageSource(item)" alt="item" />
                        <div class="item-info">
                            <div class="item-name">@item.Name</div>
                            <div class="item-meta">
                                <span class="item-type-tag @(item.IsRecipe ? "tag-recipe" : "tag-product")">
                                    @(item.IsRecipe ? "PRZEPIS" : "PRODUKT")
                                </span>
                                <span>Ilość: <span class="item-amount">@item.Amount @(item.IsRecipe ? "porcji" : "g")</span></span>
                            </div>
                            <div class="macros-row">
                                <span>B: <span class="macro-val">@item.Protein</span>g</span>
                                <span>W: <span class="macro-val">@item.Carbs</span>g</span>
                                <span>T: <span class="macro-val">@item.Fats</span>g</span>
                            </div>
                        </div>
                        <div class="item-kcal-box">
                            <div class="item-kcal">@item.Kcal</div>
                            <div class="kcal-label">kcal</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-items-box">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" />
                    <p class="no-items-text">Nie znaleźliśmy składników tego posiłku.</p>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default" Variant="Variant.Text">Zamknij</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }
    [Parameter] public ICollection<MealItem> MealItems { get; set; } = new List<MealItem>();

    private List<MealItemDisplay> displayItems = new();
    private bool isLoading = true;

    private void Cancel() => MudDialog.Cancel();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        displayItems.Clear();
        
        try 
        {
            foreach (var item in MealItems)
            {
                if (item.Type == "recipe")
                {
                    var recipe = await RecipeService.GetRecipeAsync(item.RecipeId ?? 0);
                    if (recipe != null)
                    {
                        var macros = await MealService.CalculateRecipeMacros(item.RecipeId ?? 0, item.Amount);
                        displayItems.Add(new MealItemDisplay {
                            Name = recipe.Name,
                            ImageUrl = recipe.ImageUrl,
                            IsRecipe = true,
                            Amount = item.Amount,
                            Kcal = macros?.Kcal ?? 0,
                            Protein = macros?.Protein ?? 0,
                            Carbs = macros?.Carbs ?? 0,
                            Fats = macros?.Fats ?? 0
                        });
                    }
                }
                else 
                {
                    var product = await MealService.GetProductName(item.ProductId);
                    if (product != null)
                    {
                        var macros = await MealService.CalculateProductMacros(item.ProductId ?? 0, item.Amount);
                        displayItems.Add(new MealItemDisplay {
                            Name = product.Name,
                            ImageUrl = product.ImageUrl,
                            IsRecipe = false,
                            Amount = item.Amount,
                            Kcal = macros?.Kcal ?? 0,
                            Protein = macros?.Protein ?? 0,
                            Carbs = macros?.Carbs ?? 0,
                            Fats = macros?.Fats ?? 0
                        });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd ładowania ShowMeal: {ex.Message}");
        }
        finally 
        {
            isLoading = false;
        }
    }

    private string GetImageSource(MealItemDisplay item)
    {
        if (string.IsNullOrEmpty(item.ImageUrl)) return "images/sushi.png";
        if (item.ImageUrl.StartsWith("http")) return item.ImageUrl;
        if (item.ImageUrl.StartsWith("/")) return $"{FitAura.Config.ImageBaseUrl}{item.ImageUrl}";
        return $"images/{item.ImageUrl}";
    }

    private class MealItemDisplay
    {
        public string Name { get; set; } = "";
        public string? ImageUrl { get; set; }
        public bool IsRecipe { get; set; }
        public int Amount { get; set; }
        public int Kcal { get; set; }
        public int Protein { get; set; }
        public int Carbs { get; set; }
        public int Fats { get; set; }
    }
}