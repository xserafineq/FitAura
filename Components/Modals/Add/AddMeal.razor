@using FitAura.Models
@using FitAura.Models.Records
@using FitAura.Services
@using MudBlazor
@inject FitAura.Services.ProductService ProductService
@inject HttpClient Http
@inject DayState DayState
@inject MealService MealService

<MudDialog>
    <DialogContent>
        <div id="search">
            <input id="recipe-input" type="text" placeholder="Wpisz kod kreskowy" @bind="barcode" @onkeyup="HandleKeyUp" />
            
            <button class="filter-icon" type="button" @onclick="() => GetProduct(barcode)">
                <img height="26" src="images/add_photo.svg" alt="Szukaj" />
            </button>
            
            <div class="filter-icon"><img height="25" src="images/recipes.svg" alt="Przepisy" /></div>
        </div>

        @if (myProduct != null)
        {
            <div id="img-container">
                <img id="meal-img" src="@(myProduct.ImageUrl ?? "images/sushi.png")" alt="product" />
            </div>
            <div id="content">
                <div>
                    <div id="name">@myProduct.Name 
                            @myProduct.Unit
                       </div>
                    <div id="kcal">
                        <img height="16" src="images/kcal.svg" alt="kcal" />
                        @myProduct.Kcal kcal
                    </div>
                </div>
                <div id="markets">@(myProduct.Store != "" ? "Kupisz w: " + myProduct.Store: "")</div>
                <div id="nutrients">
                    <div class="nutrient">@myProduct.Protein g białka</div>
                    <div class="nutrient">@myProduct.Carbs g węgli</div>
                    <div class="nutrient">@myProduct.Fats g tłuszczy</div>
                </div>
            </div>
        }
        else
        {
            <div style="text-align: center; margin: 20px 0; color: gray;">
                Wpisz kod kreskowy i naciśnij Enter lub kliknij ikonę, aby pobrać produkt...
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Anuluj</MudButton>
        <MudButton Color="Color.Secondary" OnClick="Submit" Disabled="@(myProduct == null)">
            Wybierz
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    private string barcode = "";
    private FitAura.Models.Product? myProduct;


    private async Task Submit()
    {
        if (myProduct != null)
        {
            var items = new List<MealItem>
            {
                new MealItem("product",myProduct.Id,null)
            };
            var meal = new AddMealRecord("sniadaniey",2000,DayState.CurrentDay.Id,items);
            await MealService.AddMeal(meal);
            MudDialog.Close(DialogResult.Ok(myProduct));
        }
    }

    private void Cancel() => MudDialog.Cancel();

    
    private async Task GetProduct(string barcode)
    {
       
        myProduct = await ProductService.GetLocalProductAsync(barcode);

    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await GetProduct(barcode);
        }
    }
}