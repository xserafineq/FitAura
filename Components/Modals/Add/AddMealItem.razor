@using FitAura.Models
@using FitAura.Models.Records
@using FitAura.Services
@using FitAura.Components.Pages
@using MudBlazor
@using ZXing
@using ZXing.SkiaSharp
@using SkiaSharp
@inject FitAura.Services.ProductService ProductService
@inject FitAura.Services.RecipeService RecipeService
@inject HttpClient Http
@inject DayState DayState
@inject MealService MealService
@inject DayService DayService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>

        <div class="section-title">Wyszukaj produkt po kodzie</div>
        <div id="barcode-search">
            <input class="meal-input meal-input-noborder" type="text" placeholder="Wpisz kod..." @bind="barcode"
            @onkeyup="HandleBarcodeKeyUp" @onblur="SearchByBarcode" />

            <InputFile id="barcode-file" OnChange="OnBarcodeFileChange" hidden accept="image/*" />
            <button class="barcode-btn" type="button" onclick="document.getElementById('barcode-file').click()">
                <img height="24" src="images/add_photo.svg" alt="Skanuj" />
            </button>
        </div>

        @if (isScanningImage)

        {
            <div class="scan-status">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" /> Skanowanie zdjęcia...
            </div>
        }


        <div class="section-title">Lub wyszukaj produkt po nazwie</div>
        <div class="search-wrapper">
            <input class="meal-input" placeholder="Wpisz nazwę produktu..." type="text" @bind="searchQuery"
            @bind:event="oninput" @onkeyup="HandleNameSearch" />
            @if (isSearching)

            {
                <div class="spinner-wrapper">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                </div>
            }
            @if (searchResults != null && searchResults.Any())

            {
                <ul class="autocomplete-list">
                    @foreach (var res in searchResults)

                    {
                        <li @onclick="() => SelectSearchResult(res)">
                            <span>@res.Name</span>
                            <span class="search-item-type">PRODUKT</span>
                        </li>
                    }
                </ul>
            }
        </div>


        <div class="section-title">Chcesz dodać cały przepis?</div>
        <button class="recipe-list-btn" @onclick="OpenRecipesBrowser">
            <MudIcon Icon="@Icons.Material.Filled.RestaurantMenu" Size="Size.Small" />
            WYBIERZ PRZEPIS Z LISTY
        </button>


        @if (selectedDisplayItem != null)

        {
            <div id="content">
                <div class="selected-item-header">
                    <img src="@ImageSource" class="selected-item-img" />
                    <div class="selected-item-name">
                        @(selectedDisplayItem.IsRecipe ? "[PRZEPIS] " : "")@selectedDisplayItem.Name
                    </div>
                    <div class="selected-item-kcal">@calculatedNutrients.Kcal kcal</div>
                </div>

                <div id="nutrients-grid">
                    <div class="nutrient-box">
                        <div class="nutrient-val">@calculatedNutrients.Protein</div>
                        <div class="nutrient-label">BIAŁKO (g)</div>
                    </div>
                    <div class="nutrient-box">
                        <div class="nutrient-val">@calculatedNutrients.Carbs</div>
                        <div class="nutrient-label">WĘGLE (g)</div>
                    </div>
                    <div class="nutrient-box">
                        <div class="nutrient-val">@calculatedNutrients.Fats</div>
                        <div class="nutrient-label">TŁUSZCZE (g)</div>
                    </div>
                </div>

                <div>
                    <label class="amount-label">
                        @(selectedDisplayItem.IsRecipe ? "Ile porcji dodajesz?" : "Ilość (g/ml):")
                    </label>
                    <input class="meal-input" type="number" @bind="amount" @bind:event="oninput"
                    @onchange="UpdateCalculation" />
                    @if (selectedDisplayItem.IsRecipe)

                    {
                        <span class="recipe-portions-info">(Przepis ma @selectedDisplayItem.OriginalPortions
                            porcji)</span>
                    }
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Anuluj</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
            Disabled="@(selectedDisplayItem == null)">
            POTWIERDŹ I DODAJ
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }



    private string barcode = "";

    private string searchQuery = "";

    private bool isSearching = false;

    private bool isScanningImage = false;

    private List<SearchItem> searchResults = new();

    private SearchItem? selectedDisplayItem;

    private int amount = 100;

    private Nutrients calculatedNutrients = new();



    private void Cancel() => MudDialog.Cancel();



    private async Task HandleBarcodeKeyUp(KeyboardEventArgs e)

    {

        if (e.Key == "Enter") await SearchByBarcode();

    }



    private async Task SearchByBarcode()

    {

        if (string.IsNullOrWhiteSpace(barcode)) return;

        var product = await ProductService.GetLocalProductAsync(barcode);

        if (product != null) SelectProduct(product);

    }



    private async Task OnBarcodeFileChange(InputFileChangeEventArgs e)

    {

        var file = e.File;

        if (file == null) return;



        isScanningImage = true;

        StateHasChanged();



        try

        {

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);

            using var ms = new MemoryStream();

            await stream.CopyToAsync(ms);

            ms.Seek(0, SeekOrigin.Begin);



            using var bitmap = SKBitmap.Decode(ms);

            if (bitmap != null)

            {

                var reader = new BarcodeReader();

                var result = reader.Decode(bitmap);



                if (result != null)

                {

                    barcode = result.Text;

                    await SearchByBarcode();

                }

            }

        }

        catch (Exception ex)

        {

            Console.WriteLine($"Błąd skanowania zdjęcia: {ex.Message}");

        }

        finally

        {

            isScanningImage = false;

            StateHasChanged();

        }

    }



    private async Task HandleNameSearch(KeyboardEventArgs e)

    {

        if (searchQuery.Length < 3) { searchResults.Clear(); return; }

        isSearching = true;

        try

        {

            var products = await ProductService.SearchProductsAsync(searchQuery);

            searchResults = products.Select(p => new SearchItem
                {
                    Id = p.Id,
                    Name = p.Name,
                    IsRecipe = false,
                    ImageUrl = p.ImageUrl,

                    Kcal = p.Kcal,
                    Protein = p.Protein,
                    Carbs = p.Carbs,
                    Fats = p.Fats,
                    Unit = p.Unit

                }).ToList();

        }

        finally { isSearching = false; }

    }



    private async Task OpenRecipesBrowser()

    {

        var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Medium, CloseButton = true };

        var parameters = new DialogParameters { ["IsSelectionMode"] = true };



        var dialog = await DialogService.ShowAsync<Recipes>("Twoje Przepisy", parameters, options);

        var result = await dialog.Result;



        if (!result.Canceled && result.Data is FitAura.Services.RecipeSummaryDto recipe)

        {

            selectedDisplayItem = new SearchItem
                {

                    Id = recipe.Id,
                    Name = recipe.Name,
                    IsRecipe = true,
                    ImageUrl = recipe.ImageUrl,

                    Kcal = recipe.TotalKcal,
                    Protein = recipe.TotalProtein,
                    Carbs = recipe.TotalCarbs,
                    Fats = recipe.TotalFats,

                    OriginalPortions = recipe.Portions

                };

            amount = 1;

            UpdateCalculation();

        }

    }



    private void SelectSearchResult(SearchItem res)

    {

        selectedDisplayItem = res;

        searchResults.Clear();

        searchQuery = "";

        amount = (int)GetBaseWeight(res.Unit);

        UpdateCalculation();

    }



    private void SelectProduct(Product p)

    {

        selectedDisplayItem = new SearchItem
            {
                Id = p.Id,
                Name = p.Name,
                IsRecipe = false,
                ImageUrl = p.ImageUrl,

                Kcal = p.Kcal,
                Protein = p.Protein,
                Carbs = p.Carbs,
                Fats = p.Fats,
                Unit = p.Unit

            };

        amount = (int)GetBaseWeight(p.Unit);

        UpdateCalculation();

    }



    private void UpdateCalculation()

    {

        if (selectedDisplayItem == null) return;



        double multiplier = 0;

        if (selectedDisplayItem.IsRecipe)

        {

            if (selectedDisplayItem.OriginalPortions > 0)

                multiplier = (double)amount / selectedDisplayItem.OriginalPortions;

        }

        else

        {

            double baseWeight = GetBaseWeight(selectedDisplayItem.Unit);

            if (baseWeight > 0)

                multiplier = (double)amount / baseWeight;

        }



        calculatedNutrients.Kcal = (int)Math.Round(selectedDisplayItem.Kcal * multiplier);

        calculatedNutrients.Protein = (int)Math.Round(selectedDisplayItem.Protein * multiplier);

        calculatedNutrients.Carbs = (int)Math.Round(selectedDisplayItem.Carbs * multiplier);

        calculatedNutrients.Fats = (int)Math.Round(selectedDisplayItem.Fats * multiplier);

    }



    private double GetBaseWeight(string unit)

    {

        if (string.IsNullOrWhiteSpace(unit)) return 100;

        unit = unit.ToLower().Replace(" ", "");

        string numberPart = new string(unit.Where(char.IsDigit).ToArray());

        if (!double.TryParse(numberPart, out double value) || value == 0) return 100;

        if (unit.Contains("kg") || (unit.Contains("l") && !unit.Contains("ml"))) return value * 1000;

        return value;

    }



    private string ImageSource

    {

        get

        {

            if (string.IsNullOrEmpty(selectedDisplayItem?.ImageUrl)) return "images/sushi.png";

            if (selectedDisplayItem.ImageUrl.StartsWith("http")) return selectedDisplayItem.ImageUrl;

            if (selectedDisplayItem.ImageUrl.StartsWith("/")) return $"{FitAura.Config.ImageBaseUrl}{selectedDisplayItem.ImageUrl}";

            return $"images/{selectedDisplayItem.ImageUrl}";

        }

    }



    private void Submit()

    {

        var fakeProduct = new Product(selectedDisplayItem.Id, "", selectedDisplayItem.Name, 0, 0, 0, "", 0, null,
        selectedDisplayItem.ImageUrl);

        MudDialog.Close(DialogResult.Ok((Product: fakeProduct, Type: selectedDisplayItem.IsRecipe ? "recipe" : "product",
        Amount: amount)));

    }



    public class SearchItem
    {

        public int Id { get; set; }

        public string Name { get; set; } = "";

        public bool IsRecipe { get; set; }

        public string? ImageUrl { get; set; }

        public int Kcal { get; set; }

        public int Protein { get; set; }

        public int Carbs { get; set; }

        public int Fats { get; set; }

        public string Unit { get; set; } = "100g";

        public int OriginalPortions { get; set; } = 1;

    }



    public class Nutrients
    {

        public int Kcal { get; set; }

        public int Protein { get; set; }

        public int Carbs { get; set; }

        public int Fats { get; set; }

    }
}