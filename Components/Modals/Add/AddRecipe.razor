@using FitAura.Models
@using FitAura.Models.Records
@using FitAura.Components.Modals
@using FitAura.Services
@using MudBlazor
@inject FitAura.Services.ProductService ProductService
@inject FitAura.Services.RecipeService RecipeService
@inject HttpClient Http
@inject DayState DayState
@inject MealService MealService
@inject IDialogService DialogService
@inject UserState UserState
@inject FitAura.Services.CategoryService CategoryService

<MudDialog>
    <DialogContent>
        <div id="upload-img">
            <label for="fileInput" class="upload-label">
                @if (string.IsNullOrEmpty(previewImageUrl))
                {
                    <div class="upload-icon"></div>
                    <div id="upload-text">Kliknij aby dodać zdjęcie</div>
                }
                else
                {
                    <img src="@previewImageUrl" class="preview-img" />
                }
            </label>
            <InputFile id="fileInput" OnChange="HandleFileSelected" accept="image/png, image/jpeg" />
        </div>

        <div id="indegredients-container">
            <span>Składniki</span>
            <div class="search-wrapper">
                <input id="search" placeholder="nazwa lub kod produktu" type="text" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
                @if (searchResults != null && searchResults.Any())
                {
                    <ul class="autocomplete-list">
                        @foreach (var prod in searchResults)
                        {
                            <li @onclick="() => SelectProduct(prod)">
                                @prod.Name @prod.Kcal kcal (@(string.IsNullOrWhiteSpace(prod.Unit) ? "100g" : prod.Unit))
                            </li>
                        }
                    </ul>
                }
            </div>
            <div id="steps-list">
                @for (int i = 0; i < items.Count; i++)
                {
                    int index = i;
                    <div id="step-item">
                        <span @key="index">@itemNames[index]</span>
                        <div class="ingredient-actions">
                            <input type="number" class="ingredient-amount-input"
                                   value="@items[index].Amount" @onchange="@(e => UpdateIngredientAmount(index, e.Value))" min="1" /> 
                            @(selectedProductsList[index].Unit?.ToLower().Contains("l") == true ? "ml" : "g")
                            <button id="delete-step" @onclick="@(() => DeleteIngredient(index))">Usuń</button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div id="steps-container">
            <span>Kroki przygotowania</span>
            <input @onkeyup="HandleKeyPress" type="text" @bind="step" id="step-input" placeholder="wpisz krok przygotowania" />
            <button id="add-step" @onclick="AddStep">Dodaj</button>
            <div id="steps-list">
                @for (int i = 0; i < steps.Count; i++)
                {
                    int index = i;
                    <div id="step-item">
                        <span @key="index" id='step-@index'>Krok @(index + 1): @steps[index]</span>
                        <button id="delete-step" @onclick="@(() => DeleteStep(index))">Usuń</button>
                    </div>
                }
            </div>
        </div>

        <div id="recipe-summary">
            <input type="text" id="recipe-name" @bind="recipeName" placeholder="nazwa przepisu" />
            <input type="number" id="protion-count" placeholder="liczba porcji" @bind="portionCount" min="1" />
            
            <div class="category-select-section">
                <span>Kategorie (kliknij aby wybrać):</span>
                <div class="category-chips">
                    @if (categories != null)
                    {
                        @foreach (var cat in categories)
                        {
                            <div class="category-chip @(selectedCategoryIds.Contains(cat.Id) ? "active" : "")" 
                                 @onclick="() => ToggleCategory(cat.Id)">
                                @cat.Name
                            </div>
                        }
                    }
                </div>
            </div>

            <div id="summary">
                <div id="nutrition-summary">
                    <span>Białko: @TotalProtein g</span>
                    <span>Węglowodany: @TotalCarbs g</span>
                    <span>Tłuszcze: @TotalFats g</span>
                </div>
                <div id="kcal-summary">
                    <span>Kcal: @TotalKcal</span>
                </div>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Anuluj</MudButton>
        <MudButton Color="Color.Secondary" OnClick="SaveRecipe">@(IsEditMode ? "Zapisz zmiany" : "Zapisz Przepis")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter] public int? EditRecipeId { get; set; }

    private bool IsEditMode => EditRecipeId.HasValue && EditRecipeId.Value > 0;
    private string? existingImageUrl;

    private List<MealItem> items = new List<MealItem>();
    private string recipeName = "";
    private List<string> itemNames = new List<string>();
    private List<string> steps = new List<string>();
    private string step = "";
    private string searchQuery = "";
    private List<Product> searchResults = new();
    private List<Product> selectedProductsList = new();
    private string previewImageUrl = "";
    private int portionCount = 1;
    private List<FitAura.Models.CategoryModel> categories = new();
    private HashSet<int> selectedCategoryIds = new HashSet<int>();
    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? selectedImageFile;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            categories = await CategoryService.GetCategoriesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Błąd pobierania kategorii: {ex.Message}");
            categories = new();
        }

        if (IsEditMode)
        {
            await LoadExistingRecipe();
        }
    }

    private async Task LoadExistingRecipe()
    {
        var recipe = await RecipeService.GetRecipeAsync(EditRecipeId!.Value);
        if (recipe == null) return;

        recipeName = recipe.Name;
        steps = recipe.Steps?.ToList() ?? new();
        portionCount = recipe.Portions;
        existingImageUrl = recipe.ImageUrl;

        if (!string.IsNullOrEmpty(recipe.ImageUrl))
        {
            previewImageUrl = recipe.ImageUrl.StartsWith("/") 
                ? $"{FitAura.Config.ImageBaseUrl}{recipe.ImageUrl}" 
                : $"images/{recipe.ImageUrl}";
        }

        // Load ingredients
        if (recipe.Ingredients != null)
        {
            foreach (var ing in recipe.Ingredients)
            {
                items.Add(new MealItem("product", ing.ProductId, null, ing.Amount));
                itemNames.Add(ing.ProductName);
                selectedProductsList.Add(new Product(
                    ing.ProductId, "", ing.ProductName, 
                    ing.Kcal, ing.Protein, ing.Fats, ing.Unit, 
                    ing.Carbs, null, null
                ));
            }
        }

        // Match categories by name
        if (recipe.Categories != null && categories != null)
        {
            foreach (var catName in recipe.Categories)
            {
                var match = categories.FirstOrDefault(c => c.Name == catName);
                if (match != null)
                    selectedCategoryIds.Add(match.Id);
            }
        }
    }

    private void ToggleCategory(int categoryId)
    {
        if (selectedCategoryIds.Contains(categoryId))
            selectedCategoryIds.Remove(categoryId);
        else
            selectedCategoryIds.Add(categoryId);
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            selectedImageFile = file;
            try
            {
                var format = file.ContentType;
                var resizedImageFile = await file.RequestImageFileAsync(format, 800, 800);
                var buffer = new byte[resizedImageFile.Size];
                await resizedImageFile.OpenReadStream(maxAllowedSize: 5120000).ReadAsync(buffer);
                var base64 = Convert.ToBase64String(buffer);
                previewImageUrl = $"data:{format};base64,{base64}";
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Błąd ładowania obrazu: {ex.Message}");
            }
        }
    }

    private double GetBaseWeight(string unit)
    {
        if (string.IsNullOrWhiteSpace(unit)) return 100;
        unit = unit.ToLower().Replace(" ", "");
        string numberPart = new string(unit.Where(char.IsDigit).ToArray());
        if (!double.TryParse(numberPart, out double value)) return 100;
        if (unit.Contains("kg")) return value * 1000;
        if (unit.Contains("l") && !unit.Contains("ml")) return value * 1000;
        return value == 0 ? 100 : value;
    }

    private int TotalKcal => items.Select((item, index) => {
        if (index >= selectedProductsList.Count) return 0;
        var prod = selectedProductsList[index];
        return (int)Math.Round(prod.Kcal * (item.Amount / GetBaseWeight(prod.Unit)));
    }).Sum();

    private int TotalProtein => items.Select((item, index) => {
        if (index >= selectedProductsList.Count) return 0;
        var prod = selectedProductsList[index];
        return (int)Math.Round(prod.Protein * (item.Amount / GetBaseWeight(prod.Unit)));
    }).Sum();

    private int TotalCarbs => items.Select((item, index) => {
        if (index >= selectedProductsList.Count) return 0;
        var prod = selectedProductsList[index];
        return (int)Math.Round(prod.Carbs * (item.Amount / GetBaseWeight(prod.Unit)));
    }).Sum();

    private int TotalFats => items.Select((item, index) => {
        if (index >= selectedProductsList.Count) return 0;
        var prod = selectedProductsList[index];
        return (int)Math.Round(prod.Fats * (item.Amount / GetBaseWeight(prod.Unit)));
    }).Sum();

    private void Cancel() => MudDialog?.Cancel();

    private async Task SaveRecipe()
    {
        if (string.IsNullOrWhiteSpace(recipeName) || items.Count == 0 || steps.Count == 0) return;

        string? finalImageUrl = IsEditMode ? existingImageUrl : null;
        if (selectedImageFile != null)
        {
            finalImageUrl = await RecipeService.UploadImageAsync(selectedImageFile);
        }

        var recipeDto = new FitAura.Services.CreateRecipeDto(
            Name: recipeName,
            ImageUrl: finalImageUrl,
            Steps: steps,
            Ingredients: items.Select((item, index) => new FitAura.Services.CreateRecipeIngredientDto(
                ProductId: item.ProductId ?? 0,
                Amount: item.Amount,
                Unit: string.IsNullOrWhiteSpace(selectedProductsList[index].Unit) ? "g" : (selectedProductsList[index].Unit.ToLower().Contains("ml") ? "ml" : "g")
            )).ToList(),
            Portions: portionCount,
            UserId: UserState.CurrentUser?.Id ?? 0,
            CategoryIds: selectedCategoryIds.ToList()
        );

        bool success;
        if (IsEditMode)
        {
            success = await RecipeService.UpdateRecipeAsync(EditRecipeId!.Value, recipeDto);
            MudDialog?.Close(DialogResult.Ok(true));
        }
        else
        {
            success = await RecipeService.CreateRecipeAsync(recipeDto);
            MudDialog?.Close(DialogResult.Ok(true));
        }
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(searchQuery) || searchQuery.Length < 3)
        {
            searchResults.Clear();
            return;
        }
        searchResults = await ProductService.SearchProductsAsync(searchQuery);
        StateHasChanged();
    }

    private void SelectProduct(Product product)
    {
        int defaultAmount = (int)GetBaseWeight(product.Unit);
        items.Add(new FitAura.Models.Records.MealItem("product", product.Id, null, defaultAmount));
        itemNames.Add(product.Name);
        selectedProductsList.Add(product);
        searchQuery = "";
        searchResults.Clear();
    }

    private void DeleteIngredient(int index)
    {
        if (index < items.Count) items.RemoveAt(index);
        if (index < itemNames.Count) itemNames.RemoveAt(index);
        if (index < selectedProductsList.Count) selectedProductsList.RemoveAt(index);
    }

    private void UpdateIngredientAmount(int index, object? value)
    {
        if (index < items.Count && int.TryParse(value?.ToString(), out int amount) && amount > 0)
        {
            items[index] = items[index] with { Amount = amount };
        }
    }

    private void AddStep()
    {
        if (string.IsNullOrEmpty(step)) return;
        steps.Add(step);
        step = "";
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddStep();
    }

    private void DeleteStep(int i) => steps.RemoveAt(i);
}