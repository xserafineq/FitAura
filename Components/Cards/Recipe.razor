@using MudBlazor
@using FitAura.Components.Modals.Show
@using System.Collections.Generic
@inject IDialogService DialogService

<button @onclick="HandleClick" class="recipe-card @(IsEditable ? "editable" : "")">
    <div class="recipe-img-wrapper">
        <img src="@ImageSource" height="200" width="200" alt="recipe-picture" />
        @if (IsEditable)
        {
            <div class="edit-badge">Edytuj</div>
        }
    </div>
    <div id="recipe-summary">
        <div id="name">@name</div>
        <div id="kcal"><img height="16" src="images/kcal.svg" alt="kcal" /> @kcal kcal</div>
        <div id="nutrients">
            <div id="nutrient">Białko @protein g</div>
            <div id="nutrient">Węgle @carbs g</div>
            <div id="nutrient">Tłuszcze @fats g</div>
        </div>
        <div id="categories">
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <span class="category">@cat</span>
                }
            }
        </div>
    </div>
</button>

@code {
    [Parameter] public int id { get; set; }
    [Parameter] public string name { get; set; } = "";
    [Parameter] public int kcal { get; set; }
    [Parameter] public int protein { get; set; }
    [Parameter] public int carbs { get; set; }
    [Parameter] public int fats { get; set; }
    [Parameter] public string img { get; set; } = "";
    [Parameter] public List<string> categories { get; set; } = new();

    [Parameter] public EventCallback<FitAura.Services.RecipeSummaryDto> OnSelected { get; set; }
    [Parameter] public bool IsEditable { get; set; } = false;

    public string ImageSource => (img != null && img.StartsWith("/")) ? $"{FitAura.Config.ImageBaseUrl}{img}" :
    $"images/{(string.IsNullOrEmpty(img) ? "img-not-found.png" : img)}";

    private async Task HandleClick()
    {
        if (OnSelected.HasDelegate)
        {
            var summary = new FitAura.Services.RecipeSummaryDto(id, name, img, kcal, protein, carbs, fats, 1, categories);
            await OnSelected.InvokeAsync(summary);
        }
        else
        {
            await OpenPreview();
        }
    }

    private async Task OpenPreview()
    {
        var options = new DialogOptions { FullWidth = true, MaxWidth = MaxWidth.Small };
        var parameters = new DialogParameters<ShowRecipe> { { x => x.RecipeId, id } };
        await DialogService.ShowAsync<ShowRecipe>("Szczegóły przepisu", parameters, options);
    }
}